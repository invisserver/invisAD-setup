APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE="Europe/Berlin"

LOG_CHANNEL=daily

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

LDAP_NAME="invis-Server AD"
LDAP_GUIDKEY=objectGUID
LDAP_LOGIN_ATTR=userPrincipalName
LDAP_LOGIN_ATTR_DESC="Anmelden mit: benutzername@localdomain"
LDAP_CONNECTION=starttls
LDAP_HOST=ldapserver
LDAP_BASE_DN="DC=invis-net,DC=loc"
LDAP_USERNAME="ldapadmindn"
LDAP_PASSWORD=admin-secret
LDAP_CACHE=false
LDAP_ALERT_ROOTDN=true
LDAP_LOGIN_OBJECTCLASS=organizationalPerson

